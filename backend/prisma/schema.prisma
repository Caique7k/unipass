datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  PLATFORM_ADMIN
  ADMIN
  DRIVER
  USER
  COORDINATOR
}

enum CompanyPlan {
  ESSENTIAL
  GROWTH
  SCALE
}

enum BillingGatewayMode {
  EXTERNAL
  PLATFORM_GATEWAY
}

enum BillingOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  UNDER_REVIEW
  ACTIVE
  REJECTED
  SUSPENDED
}

enum BillingTargetScope {
  STUDENTS
  COORDINATORS
  STUDENTS_AND_COORDINATORS
}

enum BillingChargeStatus {
  DRAFT
  SCHEDULED
  ISSUED
  SENT
  PAID
  OVERDUE
  CANCELLED
  FAILED
}

enum BillingEventSource {
  SYSTEM
  WEBHOOK
  MANUAL
}

model Company {
  id                         String       @id @default(uuid())
  name                       String
  cnpj                       String       @unique
  emailDomain                String       @unique
  plan                       CompanyPlan  @default(ESSENTIAL)
  requestedPlan              CompanyPlan?
  planChangeRequestedAt      DateTime?
  planChangeRequestedByName  String?
  planChangeRequestedByEmail String?
  contactName                String?
  contactPhone               String?
  smsVerifiedAt              DateTime?
  createdAt                  DateTime     @default(now())

  users            User[]
  students         Student[]
  buses            Bus[]
  devices          Device[]
  rfidCards        RfidCard[]
  transportEvents  TransportEvent[]
  trips            Trip[]
  routes           Route[]
  groups           Group[]
  billingSettings  CompanyBillingSettings?
  billingTemplates BillingTemplate[]
  billingCustomers BillingCustomer[]
  billingCharges   BillingCharge[]
  billingEventLogs BillingEventLog[]

  @@index([requestedPlan, planChangeRequestedAt])
}

model User {
  id                  String                 @id @default(uuid())
  name                String
  email               String                 @unique
  password            String
  role                UserRole
  active              Boolean                @default(true)
  studentId           String?                @unique
  companyId           String?
  student             Student?               @relation(fields: [studentId], references: [id])
  company             Company?               @relation(fields: [companyId], references: [id])
  confirmations       ScheduleConfirmation[]
  notificationPrompts NotificationPrompt[]
  ownedBillingCharges BillingCharge[]        @relation("BillingChargeOwner")

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Bus {
  id        String  @id @default(uuid())
  plate     String
  capacity  Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime        @default(now())
  devices   Device[]
  trips     Trip[]
  schedules RouteSchedule[]

  @@unique([plate, companyId])
  @@index([companyId])
}

model Student {
  id           String  @id @default(uuid())
  name         String
  registration String
  active       Boolean @default(true)

  email String?
  phone String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  groupId   String?
  group     Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  user      User?

  rfidCards        RfidCard[]
  transportEvents  TransportEvent[]
  routes           StudentRoute[]
  billingCustomers BillingCustomer[]
  billingCharges   BillingCharge[]
  createdAt        DateTime          @default(now())

  @@unique([registration, companyId])
  @@unique([companyId, email])
  @@index([companyId])
  @@index([groupId])
  @@index([companyId, createdAt])
}

model Group {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name           String
  nameNormalized String
  active         Boolean   @default(true)
  students       Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, nameNormalized])
  @@index([companyId, active, createdAt])
}

model Device {
  id String @id @default(uuid())

  hardwareId           String    @unique
  pairingCode          String?   @unique
  pairingCodeExpiresAt DateTime?
  pairedAt             DateTime?

  code   String? @unique
  secret String?

  name   String?
  active Boolean @default(true)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  busId String?
  bus   Bus?    @relation(fields: [busId], references: [id])

  lastLat    Float?
  lastLng    Float?
  lastUpdate DateTime?

  transportEvents TransportEvent[]

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([busId])
}

model RfidCard {
  id     String  @id @default(uuid())
  tag    String  @unique
  active Boolean @default(true)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  transportEvents TransportEvent[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model TransportEvent {
  id        String    @id @default(uuid())
  type      EventType
  createdAt DateTime  @default(now())

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  rfidCardId String?
  rfidCard   RfidCard? @relation(fields: [rfidCardId], references: [id])

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  tripId String?
  trip   Trip?   @relation(fields: [tripId], references: [id])

  @@index([companyId])
  @@index([studentId])
  @@index([deviceId])
  @@index([companyId, createdAt])
}

enum EventType {
  BOARDING
  DEBOARDING
  LEAVING
  DENIED
}

enum TripStatus {
  ACTIVE
  FINISHED
  CANCELLED
}

model Trip {
  id    String  @id @default(uuid())
  busId String?
  bus   Bus?    @relation(fields: [busId], references: [id])

  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  status    TripStatus @default(ACTIVE)

  startedAt DateTime
  endedAt   DateTime?

  createdAt DateTime @default(now())

  transportEvents TransportEvent[]

  @@index([companyId])
}

model Route {
  id     String  @id @default(uuid())
  name   String
  active Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  schedules   RouteSchedule[]
  students    StudentRoute[]
  description String?

  createdAt DateTime @default(now())

  @@index([companyId])
}

model RouteSchedule {
  id String @id @default(uuid())

  routeId String
  route   Route  @relation(fields: [routeId], references: [id])

  busId String?
  bus   Bus?    @relation(fields: [busId], references: [id])

  type  ScheduleType
  title String?

  // horário da saída
  departureTime    DateTime
  departureMinutes Int
  dayOfWeeks       Int[] // 0=domingo até 6=sábado

  // quantos minutos antes notificar
  notifyBeforeMinutes     Int   @default(30)
  notificationTimeMinutes Int
  notificationDayOfWeeks  Int[]

  active              Boolean                @default(true)
  confirmations       ScheduleConfirmation[]
  notificationPrompts NotificationPrompt[]

  createdAt DateTime @default(now())

  @@index([departureTime])
  @@index([routeId])
  @@index([active, notificationTimeMinutes])
}

model StudentRoute {
  id String @id @default(uuid())

  studentId String
  routeId   String

  student Student @relation(fields: [studentId], references: [id])
  route   Route   @relation(fields: [routeId], references: [id])

  @@unique([studentId, routeId])
  @@index([routeId])
}

model ScheduleConfirmation {
  id String @id @default(uuid())

  userId        String
  scheduleId    String
  occurrenceKey String

  user     User          @relation(fields: [userId], references: [id])
  schedule RouteSchedule @relation(fields: [scheduleId], references: [id])

  willGo Boolean

  createdAt DateTime @default(now())

  @@unique([userId, scheduleId, occurrenceKey])
  @@index([scheduleId])
}

model NotificationPrompt {
  id String @id @default(uuid())

  userId          String
  scheduleId      String
  occurrenceKey   String
  message         String
  deliveryChannel NotificationChannel      @default(IN_APP)
  status          NotificationPromptStatus @default(PENDING)
  response        Boolean?
  dispatchedAt    DateTime?
  answeredAt      DateTime?
  lastError       String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  schedule RouteSchedule @relation(fields: [scheduleId], references: [id])

  @@unique([userId, scheduleId, occurrenceKey])
  @@index([userId, status, createdAt])
  @@index([scheduleId, occurrenceKey])
}

model CompanyBillingSettings {
  id                      String                  @id @default(uuid())
  companyId               String                  @unique
  company                 Company                 @relation(fields: [companyId], references: [id])
  gatewayMode             BillingGatewayMode      @default(EXTERNAL)
  onboardingStatus        BillingOnboardingStatus @default(NOT_STARTED)
  gatewayContactName      String?
  gatewayContactEmail     String?
  gatewayContactPhone     String?
  legalEntityName         String?
  legalDocument           String?
  bankInfoSummary         String?
  defaultAmountCents      Int?
  defaultDueDay           Int?
  lgpdAcceptedAt          DateTime?
  platformTermsAcceptedAt DateTime?
  submittedAt             DateTime?
  reviewedAt              DateTime?
  reviewNotes             String?
  asaasAccountId          String?                 @unique
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([gatewayMode, onboardingStatus])
}

model BillingTemplate {
  id                 String             @id @default(uuid())
  companyId          String
  company            Company            @relation(fields: [companyId], references: [id])
  name               String
  description        String?
  active             Boolean            @default(true)
  targetScope        BillingTargetScope @default(STUDENTS)
  amountCents        Int
  dueDay             Int
  notifyOnGeneration Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  charges BillingCharge[]

  @@index([companyId, active, createdAt])
}

model BillingCustomer {
  id              String            @id @default(uuid())
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id])
  studentId       String?
  student         Student?          @relation(fields: [studentId], references: [id], onDelete: SetNull)
  name            String
  email           String?
  document        String?
  phone           String?
  asaasCustomerId String?           @unique
  charges         BillingCharge[]
  eventLogs       BillingEventLog[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([companyId, createdAt])
  @@index([studentId])
}

model BillingCharge {
  id                     String              @id @default(uuid())
  companyId              String
  company                Company             @relation(fields: [companyId], references: [id])
  templateId             String?
  template               BillingTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  ownerUserId            String?
  ownerUser              User?               @relation("BillingChargeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  studentId              String?
  student                Student?            @relation(fields: [studentId], references: [id], onDelete: SetNull)
  customerId             String?
  customer               BillingCustomer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  recipientName          String
  recipientEmail         String?
  recipientDocument      String?
  description            String
  amountCents            Int
  dueDate                DateTime
  status                 BillingChargeStatus @default(DRAFT)
  gatewayChargeId        String?             @unique
  externalReference      String?
  bankSlipUrl            String?
  gatewayInvoiceUrl      String?
  gatewayStatus          String?
  gatewayStatusUpdatedAt DateTime?
  paidAt                 DateTime?
  lastNotifiedAt         DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  eventLogs              BillingEventLog[]

  @@unique([companyId, externalReference])
  @@index([companyId, status, dueDate])
  @@index([ownerUserId, status, dueDate])
  @@index([studentId, dueDate])
  @@index([customerId, dueDate])
}

model BillingEventLog {
  id               String             @id @default(uuid())
  companyId        String?
  company          Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  chargeId         String?
  charge           BillingCharge?     @relation(fields: [chargeId], references: [id], onDelete: SetNull)
  customerId       String?
  customer         BillingCustomer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  eventType        String
  source           BillingEventSource @default(SYSTEM)
  gatewayEvent     String?
  deduplicationKey String?            @unique
  payload          Json?
  metadata         Json?
  processedAt      DateTime?
  createdAt        DateTime           @default(now())

  @@index([companyId, createdAt])
  @@index([chargeId, createdAt])
  @@index([customerId, createdAt])
}

enum ScheduleType {
  GO // ida
  BACK // volta
  SHIFT // turnos (empresa/usina)
}

enum NotificationChannel {
  IN_APP
  PUSH
}

enum NotificationPromptStatus {
  PENDING
  DISPATCHED
  ANSWERED
  EXPIRED
  FAILED
}
