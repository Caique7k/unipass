datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  OPERATOR
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  createdAt DateTime @default(now())

  users           User[]
  students        Student[]
  buses           Bus[]
  devices         Device[]
  rfidCards       RfidCard[]
  transportEvents TransportEvent[]
  trips           Trip[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Bus {
  id        String  @id @default(uuid())
  plate     String  @unique
  capacity  Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  devices   Device[]
  trips     Trip[]

  @@index([companyId])
}

model Student {
  id           String  @id @default(uuid())
  name         String
  registration String
  active       Boolean @default(true)

  email String?
  phone String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  rfidCards       RfidCard[]
  transportEvents TransportEvent[]

  createdAt DateTime @default(now())

  @@unique([registration, companyId])
  @@index([companyId])
  @@index([companyId, createdAt])
}

model Device {
  id         String  @id @default(uuid())
  identifier String  @unique
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  busId      String?
  bus        Bus?    @relation(fields: [busId], references: [id])

  lastLat    Float?
  lastLng    Float?
  lastUpdate DateTime?

  transportEvents TransportEvent[]

  createdAt DateTime @default(now())

  @@index([companyId, busId])
}

model RfidCard {
  id     String  @id @default(uuid())
  tag    String  @unique
  active Boolean @default(true)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  transportEvents TransportEvent[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model TransportEvent {
  id        String    @id @default(uuid())
  type      EventType
  createdAt DateTime  @default(now())

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  rfidCardId String?
  rfidCard   RfidCard? @relation(fields: [rfidCardId], references: [id])

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  tripId String?
  trip   Trip?   @relation(fields: [tripId], references: [id])

  @@index([companyId])
  @@index([studentId])
  @@index([deviceId])
  @@index([companyId, createdAt])
}

enum EventType {
  BOARDING
  DEBOARDING  
  LEAVING
  DENIED
}

enum TripStatus {
  ACTIVE
  FINISHED
  CANCELLED
}

model Trip {
  id    String  @id @default(uuid())
  busId String?
  bus   Bus?    @relation(fields: [busId], references: [id])

  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  status    TripStatus @default(ACTIVE)

  startedAt DateTime
  endedAt   DateTime?

  createdAt DateTime @default(now())

  transportEvents TransportEvent[]

  @@index([companyId])
}
