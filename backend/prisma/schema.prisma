datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  PLATFORM_ADMIN
  ADMIN
  DRIVER
  USER
  COORDINATOR
}

enum CompanyPlan {
  ESSENTIAL
  GROWTH
  SCALE
}

model Company {
  id            String      @id @default(uuid())
  name          String
  cnpj          String      @unique
  emailDomain   String      @unique
  plan          CompanyPlan @default(ESSENTIAL)
  contactName   String?
  contactPhone  String?
  smsVerifiedAt DateTime?
  createdAt     DateTime    @default(now())

  users           User[]
  students        Student[]
  buses           Bus[]
  devices         Device[]
  rfidCards       RfidCard[]
  transportEvents TransportEvent[]
  trips           Trip[]
  routes          Route[]
}

model User {
  id            String                 @id @default(uuid())
  name          String
  email         String                 @unique
  password      String
  role          UserRole
  active        Boolean                @default(true)
  studentId     String?                @unique
  companyId     String?
  student       Student?               @relation(fields: [studentId], references: [id])
  company       Company?               @relation(fields: [companyId], references: [id])
  confirmations ScheduleConfirmation[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Bus {
  id        String  @id @default(uuid())
  plate     String
  capacity  Int
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime        @default(now())
  devices   Device[]
  trips     Trip[]
  schedules RouteSchedule[]

  @@unique([plate, companyId])
  @@index([companyId])
}

model Student {
  id           String  @id @default(uuid())
  name         String
  registration String
  active       Boolean @default(true)

  email String?
  phone String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  user      User?

  rfidCards       RfidCard[]
  transportEvents TransportEvent[]
  routes          StudentRoute[]
  createdAt       DateTime         @default(now())

  @@unique([registration, companyId])
  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, createdAt])
}

model Device {
  id String @id @default(uuid())

  hardwareId           String    @unique
  pairingCode          String?   @unique
  pairingCodeExpiresAt DateTime?
  pairedAt             DateTime?

  code   String? @unique
  secret String?

  name   String?
  active Boolean @default(true)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  busId String?
  bus   Bus?    @relation(fields: [busId], references: [id])

  lastLat    Float?
  lastLng    Float?
  lastUpdate DateTime?

  transportEvents TransportEvent[]

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([busId])
}

model RfidCard {
  id     String  @id @default(uuid())
  tag    String  @unique
  active Boolean @default(true)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  transportEvents TransportEvent[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model TransportEvent {
  id        String    @id @default(uuid())
  type      EventType
  createdAt DateTime  @default(now())

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  rfidCardId String?
  rfidCard   RfidCard? @relation(fields: [rfidCardId], references: [id])

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  tripId String?
  trip   Trip?   @relation(fields: [tripId], references: [id])

  @@index([companyId])
  @@index([studentId])
  @@index([deviceId])
  @@index([companyId, createdAt])
}

enum EventType {
  BOARDING
  DEBOARDING
  LEAVING
  DENIED
}

enum TripStatus {
  ACTIVE
  FINISHED
  CANCELLED
}

model Trip {
  id    String  @id @default(uuid())
  busId String?
  bus   Bus?    @relation(fields: [busId], references: [id])

  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  status    TripStatus @default(ACTIVE)

  startedAt DateTime
  endedAt   DateTime?

  createdAt DateTime @default(now())

  transportEvents TransportEvent[]

  @@index([companyId])
}

model Route {
  id   String @id @default(uuid())
  name String
  active Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  schedules   RouteSchedule[]
  students    StudentRoute[]
  description String?

  createdAt DateTime @default(now())

  @@index([companyId])
}

model RouteSchedule {
  id String @id @default(uuid())

  routeId String
  route   Route  @relation(fields: [routeId], references: [id])

  busId String?
  bus   Bus?    @relation(fields: [busId], references: [id])

  type  ScheduleType
  title String?

  // horário da saída
  departureTime DateTime
  dayOfWeek     Int? // 0=domingo até 6=sábado

  // quantos minutos antes notificar
  notifyBeforeMinutes Int @default(30)

  active        Boolean                @default(true)
  confirmations ScheduleConfirmation[]

  createdAt DateTime @default(now())

  @@index([departureTime])
  @@index([routeId])
}

model StudentRoute {
  id String @id @default(uuid())

  studentId String
  routeId   String

  student Student @relation(fields: [studentId], references: [id])
  route   Route   @relation(fields: [routeId], references: [id])

  @@unique([studentId, routeId])
  @@index([routeId])
}

model ScheduleConfirmation {
  id String @id @default(uuid())

  userId     String
  scheduleId String

  user     User          @relation(fields: [userId], references: [id])
  schedule RouteSchedule @relation(fields: [scheduleId], references: [id])

  willGo Boolean

  createdAt DateTime @default(now())

  @@unique([userId, scheduleId])
  @@index([scheduleId])
}

enum ScheduleType {
  GO // ida
  BACK // volta
  SHIFT // turnos (empresa/usina)
}
